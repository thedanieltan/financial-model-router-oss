{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/thedanieltan/financial-model-router-oss/fmr/contracts/workbook-calculation-request.v1.schema.json",
  "title": "FMR workbook calculation request v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "filename", "output_filename", "workbook_base64", "write_plan", "execution_receipt", "timeout_seconds"],
  "properties": {
    "contract_version": {"const": "workbook-calculation-request.v1"},
    "filename": {"type": "string", "minLength": 1, "maxLength": 255, "pattern": "^[^/\\\\]+\\.xlsx$"},
    "output_filename": {"type": "string", "minLength": 1, "maxLength": 255, "pattern": "^[^/\\\\]+\\.xlsx$"},
    "workbook_base64": {"type": "string", "minLength": 1},
    "write_plan": {"type": "object"},
    "execution_receipt": {"type": "object"},
    "timeout_seconds": {"type": "integer", "minimum": 1, "maximum": 600}
  }
}
