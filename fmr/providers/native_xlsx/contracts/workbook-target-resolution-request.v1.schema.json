{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/thedanieltan/financial-model-router-oss/fmr/contracts/workbook-target-resolution-request.v1.schema.json",
  "title": "FMR workbook target resolution request",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "workbook_analysis", "workbook_patch"],
  "properties": {
    "contract_version": {
      "const": "workbook-target-resolution-request.v1"
    },
    "workbook_analysis": {
      "type": "object",
      "required": ["contract_version"],
      "properties": {
        "contract_version": {"const": "workbook-analysis.v1"}
      }
    },
    "workbook_patch": {
      "type": "object",
      "required": ["contract_version"],
      "properties": {
        "contract_version": {"const": "workbook-patch.v1"}
      }
    }
  }
}
