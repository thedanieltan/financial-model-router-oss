{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/thedanieltan/financial-model-router-oss/fmr/contracts/model-request.v1.schema.json",
  "title": "Financial Model Router request",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "objective", "role"],
  "properties": {
    "contract_version": {"const": "model-request.v1"},
    "objective": {"type": "string", "minLength": 1},
    "role": {"type": "string", "minLength": 1},
    "available_data": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "workbook_capabilities": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "assumptions": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
  }
}
