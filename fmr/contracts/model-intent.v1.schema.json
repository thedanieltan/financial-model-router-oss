{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/thedanieltan/financial-model-router-oss/blob/main/fmr/contracts/model-intent.v1.schema.json",
  "title": "FMR model intent v1",
  "type": "object",
  "required": ["contract_version", "intent_id", "intent_sha256", "objective", "decision_context", "requested_outcomes", "planning_horizon", "industry", "context", "available_data", "available_assumptions", "existing_model", "output_formats", "constraints", "privacy_constraints", "licensing_constraints", "unanswered_questions"],
  "properties": {
    "contract_version": {"const": "model-intent.v1"},
    "intent_id": {"type": "string", "pattern": "^fmri_[a-f0-9]{24}$"},
    "intent_sha256": {"$ref": "#/$defs/sha256"},
    "objective": {"type": "string", "minLength": 1, "maxLength": 1000},
    "decision_context": {"enum": ["acquisition", "financing", "liquidity", "operating_plan", "other", "refinancing", "unknown", "valuation"]},
    "requested_outcomes": {"$ref": "#/$defs/strings"},
    "planning_horizon": {"oneOf": [{"type": "null"}, {"type": "object", "required": ["value", "unit"], "properties": {"value": {"type": "integer", "minimum": 1}, "unit": {"enum": ["months", "years", "periods"]}}, "additionalProperties": false}]},
    "industry": {"type": ["string", "null"], "minLength": 1},
    "context": {"type": "object"},
    "available_data": {"$ref": "#/$defs/strings"},
    "available_assumptions": {"$ref": "#/$defs/strings"},
    "existing_model": {"type": "object"},
    "output_formats": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._+-]*$"}, "uniqueItems": true},
    "constraints": {"type": "object"},
    "privacy_constraints": {"$ref": "#/$defs/strings"},
    "licensing_constraints": {"$ref": "#/$defs/strings"},
    "unanswered_questions": {"$ref": "#/$defs/strings"}
  },
  "additionalProperties": false,
  "$defs": {"strings": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}, "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
}
