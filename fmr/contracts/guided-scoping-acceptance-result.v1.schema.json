{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/thedanieltan/financial-model-router-oss/blob/main/fmr/contracts/guided-scoping-acceptance-result.v1.schema.json",
  "title": "FMR guided scoping acceptance result v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "acceptance_id", "acceptance_sha256", "corpus_id", "corpus_version", "corpus_sha256", "implementation_status", "practitioner_status", "production_status", "case_results", "review_references", "blockers"],
  "properties": {
    "contract_version": {"const": "guided-scoping-acceptance-result.v1"},
    "acceptance_id": {"type": "string", "pattern": "^fmrsa_[a-f0-9]{24}$"},
    "acceptance_sha256": {"$ref": "#/$defs/sha256"},
    "corpus_id": {"$ref": "#/$defs/id"},
    "corpus_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "corpus_sha256": {"$ref": "#/$defs/sha256"},
    "implementation_status": {"enum": ["passed", "failed"]},
    "practitioner_status": {"enum": ["pending", "accepted", "rejected"]},
    "production_status": {"enum": ["not_accepted", "accepted"]},
    "case_results": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/caseResult"}},
    "review_references": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "blockers": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "caseResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["case_id", "case_sha256", "data_classification", "status", "assessment_id", "assessment_sha256", "state", "candidate_outcomes", "selected_family", "compiled_job_sha256", "issues"],
      "properties": {
        "case_id": {"$ref": "#/$defs/id"},
        "case_sha256": {"$ref": "#/$defs/sha256"},
        "data_classification": {"enum": ["synthetic", "anonymized"]},
        "status": {"enum": ["passed", "failed"]},
        "assessment_id": {"type": "string", "pattern": "^fmrs_[a-f0-9]{24}$"},
        "assessment_sha256": {"$ref": "#/$defs/sha256"},
        "state": {"type": "string", "minLength": 1},
        "candidate_outcomes": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["family_id", "suitability"], "properties": {"family_id": {"$ref": "#/$defs/id"}, "suitability": {"enum": ["eligible", "possible", "blocked", "unsupported"]}}}},
        "selected_family": {"type": ["string", "null"]},
        "compiled_job_sha256": {"oneOf": [{"$ref": "#/$defs/sha256"}, {"type": "null"}]},
        "issues": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    }
  }
}
