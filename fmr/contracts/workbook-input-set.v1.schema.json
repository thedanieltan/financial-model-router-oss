{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/thedanieltan/financial-model-router-oss/fmr/contracts/workbook-input-set.v1.schema.json",
  "title": "FMR workbook input set v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "input_set_id",
    "write_plan_id",
    "write_plan_sha256",
    "execution_id",
    "execution_receipt_sha256",
    "source",
    "bindings",
    "controls"
  ],
  "properties": {
    "contract_version": {"const": "workbook-input-set.v1"},
    "input_set_id": {"type": "string", "pattern": "^fmri_[0-9a-f]{24}$"},
    "write_plan_id": {"type": "string", "pattern": "^fmrw_[0-9a-f]{24}$"},
    "write_plan_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "execution_id": {"type": "string", "pattern": "^fmre_[0-9a-f]{24}$"},
    "execution_receipt_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "reference", "sha256", "size_bytes"],
      "properties": {
        "kind": {"enum": ["csv", "json", "manual", "system"]},
        "reference": {"type": "string", "minLength": 1},
        "sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
        "size_bytes": {"type": ["integer", "null"], "minimum": 0}
      }
    },
    "bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["record_id", "value_type", "values", "source_ref"],
        "properties": {
          "record_id": {"type": "string", "pattern": "^fmrw_[0-9]{6}$"},
          "value_type": {"enum": ["number", "boolean"]},
          "values": {
            "type": "array",
            "minItems": 1,
            "items": {"type": ["number", "boolean"]}
          },
          "source_ref": {"type": "string", "minLength": 1}
        }
      }
    },
    "controls": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
  }
}
