{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/thedanieltan/financial-model-router-oss/blob/main/fmr/contracts/deployment-acceptance-evidence.v1.schema.json",
  "title": "FMR deployment acceptance evidence v1",
  "type": "object",
  "required": ["contract_version", "environment_id", "gates"],
  "properties": {
    "contract_version": {"const": "deployment-acceptance-evidence.v1"},
    "environment_id": {"type": "string", "minLength": 1},
    "gates": {"type": "object", "required": ["filesystem_durability", "backup_restore_drill", "process_supervision", "resource_limits", "secret_manager_integration", "security_review", "operator_acceptance"], "properties": {
      "filesystem_durability": {"$ref": "#/$defs/evidence"}, "backup_restore_drill": {"$ref": "#/$defs/evidence"}, "process_supervision": {"$ref": "#/$defs/evidence"}, "resource_limits": {"$ref": "#/$defs/evidence"}, "secret_manager_integration": {"$ref": "#/$defs/evidence"}, "security_review": {"$ref": "#/$defs/evidence"}, "operator_acceptance": {"$ref": "#/$defs/evidence"}
    }, "additionalProperties": false}
  },
  "additionalProperties": false,
  "$defs": {"evidence": {"type": "object", "required": ["status", "reference"], "properties": {"status": {"enum": ["passed", "failed", "not_run"]}, "reference": {"type": "string"}}, "additionalProperties": false}}
}
