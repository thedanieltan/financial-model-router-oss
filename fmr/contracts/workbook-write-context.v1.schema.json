{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/thedanieltan/financial-model-router-oss/fmr/contracts/workbook-write-context.v1.schema.json",
  "title": "FMR workbook write context v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "period_labels", "bindings"],
  "properties": {
    "contract_version": {"const": "workbook-write-context.v1"},
    "period_labels": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "bindings": {
      "type": "object",
      "propertyNames": {"pattern": "^fmr\\.[a-z0-9_.-]+\\.v1$"},
      "additionalProperties": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["binding_type", "sheet_name", "coordinate"],
            "properties": {
              "binding_type": {"const": "range"},
              "sheet_name": {"type": "string", "minLength": 1},
              "coordinate": {"type": "string", "pattern": "^[A-Z]{1,3}[1-9][0-9]*(?::[A-Z]{1,3}[1-9][0-9]*)?$"},
              "alignment": {"enum": ["match", "whole_range"]}
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["binding_type", "value"],
            "properties": {
              "binding_type": {"const": "constant"},
              "value": {"type": ["number", "boolean"]}
            }
          }
        ]
      }
    }
  }
}
