{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/thedanieltan/financial-model-router-oss/fmr/contracts/workbook-calculation-acceptance.v1.schema.json",
  "title": "FMR workbook calculation acceptance v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version", "acceptance_id", "write_plan_id", "write_plan_sha256",
    "execution_id", "execution_receipt_sha256", "input", "output", "engine",
    "status", "summary", "immutable_verification", "formula_checks",
    "workbook_formula_scan", "controls"
  ],
  "properties": {
    "contract_version": {"const": "workbook-calculation-acceptance.v1"},
    "acceptance_id": {"type": "string", "pattern": "^fmrc_[0-9a-f]{24}$"},
    "write_plan_id": {"type": "string", "pattern": "^fmrw_[0-9a-f]{24}$"},
    "write_plan_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "execution_id": {"type": "string", "pattern": "^fmre_[0-9a-f]{24}$"},
    "execution_receipt_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "input": {"$ref": "#/$defs/inputFile"},
    "output": {"$ref": "#/$defs/file"},
    "engine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "adapter"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "adapter": {"type": "string", "minLength": 1},
        "return_code": {"const": 0},
        "stdout_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "stderr_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "status": {"enum": ["passed", "failed"]},
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "immutable_record_count", "immutable_failure_count", "input_cell_count",
        "populated_input_cell_count", "planned_formula_count",
        "planned_formula_failure_count", "workbook_formula_count",
        "workbook_formula_error_count", "missing_cached_value_count"
      ],
      "properties": {
        "immutable_record_count": {"type": "integer", "minimum": 0},
        "immutable_failure_count": {"type": "integer", "minimum": 0},
        "input_cell_count": {"type": "integer", "minimum": 0},
        "populated_input_cell_count": {"type": "integer", "minimum": 0},
        "planned_formula_count": {"type": "integer", "minimum": 0},
        "planned_formula_failure_count": {"type": "integer", "minimum": 0},
        "workbook_formula_count": {"type": "integer", "minimum": 0},
        "workbook_formula_error_count": {"type": "integer", "minimum": 0},
        "missing_cached_value_count": {"type": "integer", "minimum": 0}
      }
    },
    "immutable_verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verified_record_ids", "failed_record_ids", "failures", "verified_record_count", "input_cell_count", "populated_input_cell_count"],
      "properties": {
        "verified_record_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "failed_record_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "failures": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["scope", "record_id", "issue_code"],
            "properties": {
              "scope": {"enum": ["input", "output"]},
              "record_id": {"type": "string", "minLength": 1},
              "issue_code": {"type": "string", "minLength": 1}
            }
          }
        },
        "verified_record_count": {"type": "integer", "minimum": 0},
        "input_cell_count": {"type": "integer", "minimum": 0},
        "populated_input_cell_count": {"type": "integer", "minimum": 0}
      }
    },
    "formula_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["check_id", "record_id", "formula_identifier", "sheet_name", "coordinate", "status", "observed_type", "observed_sign", "issue_codes"],
        "properties": {
          "check_id": {"type": "string", "minLength": 1},
          "record_id": {"type": "string", "minLength": 1},
          "formula_identifier": {"type": "string", "minLength": 1},
          "sheet_name": {"type": "string", "minLength": 1},
          "coordinate": {"type": "string", "minLength": 1},
          "status": {"enum": ["passed", "failed"]},
          "observed_type": {"type": "string", "minLength": 1},
          "observed_sign": {"type": "string", "minLength": 1},
          "issue_codes": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "workbook_formula_scan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["formula_count", "error_count", "missing_cached_value_count"],
      "properties": {
        "formula_count": {"type": "integer", "minimum": 0},
        "error_count": {"type": "integer", "minimum": 0},
        "missing_cached_value_count": {"type": "integer", "minimum": 0}
      }
    },
    "controls": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
  },
  "$defs": {
    "file": {
      "type": "object",
      "additionalProperties": false,
      "required": ["filename", "sha256", "size_bytes"],
      "properties": {
        "filename": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "size_bytes": {"type": "integer", "minimum": 1}
      }
    },
    "inputFile": {
      "allOf": [
        {"$ref": "#/$defs/file"},
        {
          "type": "object",
          "required": ["matches_execution_output_hash"],
          "properties": {"matches_execution_output_hash": {"type": "boolean"}}
        }
      ]
    }
  }
}
