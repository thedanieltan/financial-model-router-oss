{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/thedanieltan/financial-model-router-oss/blob/main/fmr/contracts/provider-sdk-package-result.v1.schema.json",
  "title": "FMR provider SDK package result v1",
  "type": "object",
  "required": ["contract_version", "provider_id", "path", "sha256", "size_bytes", "member_count"],
  "properties": {
    "contract_version": {"const": "provider-sdk-package-result.v1"},
    "provider_id": {"type": "string", "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"},
    "path": {"type": "string", "minLength": 1},
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "size_bytes": {"type": "integer", "minimum": 1},
    "member_count": {"type": "integer", "minimum": 1}
  },
  "additionalProperties": false
}
