{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/thedanieltan/financial-model-router-oss/blob/main/fmr/contracts/provider-manifest.v1.schema.json",
  "title": "FMR provider manifest v1",
  "type": "object",
  "required": ["contract_version", "provider_id", "version", "execution_mode", "network_required", "license", "open_source", "privacy_behavior", "runtime_dependencies", "determinism_level", "validation_capabilities", "limitations", "secret_requirements", "executor_entry_point", "packages"],
  "properties": {
    "contract_version": {"const": "provider-manifest.v1"},
    "provider_id": {"$ref": "#/$defs/id"},
    "version": {"$ref": "#/$defs/version"},
    "execution_mode": {"enum": ["local", "remote", "handoff_only"]},
    "network_required": {"type": "boolean"},
    "license": {"type": "string", "minLength": 1},
    "open_source": {"type": "boolean"},
    "privacy_behavior": {"$ref": "#/$defs/nonEmptyStrings"},
    "runtime_dependencies": {"$ref": "#/$defs/strings"},
    "determinism_level": {"$ref": "#/$defs/id"},
    "validation_capabilities": {"$ref": "#/$defs/nonEmptyStrings"},
    "limitations": {"$ref": "#/$defs/strings"},
    "secret_requirements": {"$ref": "#/$defs/strings"},
    "executor_entry_point": {"$ref": "#/$defs/id"},
    "packages": {"type": "array", "minItems": 1, "items": {"$ref": "model-package-manifest.v1.schema.json"}}
  },
  "additionalProperties": false,
  "$defs": {
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[a-z]+[0-9]+)?$"},
    "id": {"type": "string", "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"},
    "strings": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "nonEmptyStrings": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
  }
}
