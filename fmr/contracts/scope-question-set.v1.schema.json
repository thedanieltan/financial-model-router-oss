{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/thedanieltan/financial-model-router-oss/blob/main/fmr/contracts/scope-question-set.v1.schema.json",
  "title": "FMR scope question set v1",
  "type": "object",
  "required": ["contract_version", "version", "questions"],
  "properties": {
    "contract_version": {"const": "scope-question-set.v1"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "questions": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["question_id", "prompt", "answer_type", "intent_field", "options", "help_text"], "properties": {"question_id": {"$ref": "#/$defs/id"}, "prompt": {"$ref": "#/$defs/text"}, "answer_type": {"enum": ["boolean", "single_select"]}, "intent_field": {"$ref": "#/$defs/text"}, "options": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["value", "label"], "properties": {"value": {"$ref": "#/$defs/text"}, "label": {"$ref": "#/$defs/text"}}, "additionalProperties": false}}, "help_text": {"$ref": "#/$defs/text"}}, "additionalProperties": false}}
  },
  "additionalProperties": false,
  "$defs": {"id": {"type": "string", "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"}, "text": {"type": "string", "minLength": 1}}
}
