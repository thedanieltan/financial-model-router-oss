{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/thedanieltan/financial-model-router-oss/blob/main/fmr/contracts/execution-result.v1.schema.json",
  "title": "FMR execution result v1",
  "type": "object",
  "required": ["contract_version", "execution_id", "handoff_reference", "provider", "package", "state", "output_artifact_references", "validation_status", "errors_and_blockers", "error_category", "retry_eligible", "output_hashes", "provider_receipt", "idempotency_key_sha256"],
  "properties": {
    "contract_version": {"const": "execution-result.v1"},
    "execution_id": {"type": "string", "pattern": "^fmrx_[a-f0-9]{24}$"},
    "handoff_reference": {"type": "object", "required": ["handoff_id", "sha256"], "properties": {"handoff_id": {"type": "string", "pattern": "^fmrh_[a-f0-9]{24}$"}, "sha256": {"$ref": "#/$defs/sha256"}}, "additionalProperties": false},
    "provider": {"$ref": "#/$defs/providerIdentity"},
    "package": {"$ref": "#/$defs/packageIdentity"},
    "state": {"enum": ["accepted", "preparing", "blocked", "running", "validating", "completed", "failed", "cancelled"]},
    "output_artifact_references": {"type": "array", "items": {"$ref": "#/$defs/artifact"}},
    "validation_status": {"enum": ["pending", "blocked", "passed", "failed"]},
    "errors_and_blockers": {"type": "array", "items": {"type": "string"}},
    "error_category": {"enum": ["invalid_input", "provider_failure", null]},
    "retry_eligible": {"type": "boolean"},
    "output_hashes": {"type": "array", "items": {"$ref": "#/$defs/sha256"}, "uniqueItems": true},
    "provider_receipt": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/receipt"}]},
    "idempotency_key_sha256": {"$ref": "#/$defs/sha256"}
  },
  "additionalProperties": false,
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "providerIdentity": {"type": "object", "required": ["provider_id", "version"], "properties": {"provider_id": {"type": "string"}, "version": {"type": "string"}}, "additionalProperties": false},
    "packageIdentity": {"type": "object", "required": ["package_id", "version"], "properties": {"package_id": {"type": "string"}, "version": {"type": "string"}}, "additionalProperties": false},
    "artifact": {"type": "object", "required": ["kind", "format", "path", "sha256", "size_bytes"], "properties": {"kind": {"type": "string"}, "format": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._+-]*$"}, "path": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/sha256"}, "size_bytes": {"type": "integer", "minimum": 0}}, "additionalProperties": false},
    "receipt": {"type": "object", "required": ["sha256", "version", "payload"], "properties": {"sha256": {"$ref": "#/$defs/sha256"}, "version": {"type": "string", "minLength": 1}, "payload": {"type": "object"}}, "additionalProperties": false}
  }
}
