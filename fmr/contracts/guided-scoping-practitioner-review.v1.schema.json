{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/thedanieltan/financial-model-router-oss/blob/main/fmr/contracts/guided-scoping-practitioner-review.v1.schema.json",
  "title": "FMR guided scoping practitioner review v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "review_id", "review_sha256", "case_id", "case_sha256", "assessment_sha256", "reviewer_role", "status", "evidence_reference"],
  "properties": {
    "contract_version": {"const": "guided-scoping-practitioner-review.v1"},
    "review_id": {"type": "string", "pattern": "^fmrsr_[a-f0-9]{24}$"},
    "review_sha256": {"$ref": "#/$defs/sha256"},
    "case_id": {"type": "string", "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"},
    "case_sha256": {"$ref": "#/$defs/sha256"},
    "assessment_sha256": {"$ref": "#/$defs/sha256"},
    "reviewer_role": {"type": "string", "minLength": 1},
    "status": {"enum": ["accepted", "rejected"]},
    "evidence_reference": {"type": "string", "minLength": 1}
  },
  "$defs": {"sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}}
}
