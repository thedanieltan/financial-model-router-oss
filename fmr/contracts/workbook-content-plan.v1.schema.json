{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/thedanieltan/financial-model-router-oss/fmr/contracts/workbook-content-plan.v1.schema.json",
  "title": "Workbook content plan v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "content_plan_id",
    "coordinate_plan_id",
    "coordinate_plan_sha256",
    "content_specs_sha256",
    "source",
    "ready_for_executor",
    "execution_supported_by_this_release",
    "blockers",
    "operation_contents",
    "controls"
  ],
  "properties": {
    "contract_version": {"const": "workbook-content-plan.v1"},
    "content_plan_id": {"type": "string", "pattern": "^fmrt_[0-9a-f]{24}$"},
    "coordinate_plan_id": {"type": "string", "pattern": "^fmrc_[0-9a-f]{24}$"},
    "coordinate_plan_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "content_specs_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["filename", "sha256", "size_bytes"],
      "properties": {
        "filename": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "size_bytes": {"type": "integer", "minimum": 0}
      }
    },
    "ready_for_executor": {"type": "boolean"},
    "execution_supported_by_this_release": {"const": false},
    "blockers": {"type": "array", "items": {"type": "string"}},
    "operation_contents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sequence",
          "operation_id",
          "source_operation",
          "content_spec_ref",
          "coordinate_plan_status",
          "status",
          "title",
          "slots",
          "validation_ids",
          "blockers"
        ],
        "properties": {
          "sequence": {"type": "integer", "minimum": 1},
          "operation_id": {"type": "string", "minLength": 1},
          "source_operation": {"type": "string", "minLength": 1},
          "content_spec_ref": {"type": "string", "pattern": "^fmr://workbook-content-specs/.+/v1$"},
          "coordinate_plan_status": {"type": "string", "minLength": 1},
          "status": {
            "enum": ["blocked", "planned_content", "reference_only", "satisfied_existing"]
          },
          "title": {"type": "string", "minLength": 1},
          "slots": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "slot_id",
                "sheet_name",
                "sheet_position",
                "coordinate",
                "content_kind",
                "label",
                "identifier",
                "format_role",
                "editable"
              ],
              "properties": {
                "slot_id": {"type": "string", "minLength": 1},
                "sheet_name": {"type": ["string", "null"]},
                "sheet_position": {"type": ["integer", "null"], "minimum": 1},
                "coordinate": {
                  "type": ["string", "null"],
                  "pattern": "^[A-Z]{1,3}[1-9][0-9]*:[A-Z]{1,3}[1-9][0-9]*$"
                },
                "content_kind": {
                  "enum": [
                    "input_placeholder",
                    "label",
                    "formula_identifier",
                    "period_header",
                    "reference_identifier",
                    "validation_identifier"
                  ]
                },
                "label": {"type": ["string", "null"]},
                "identifier": {"type": ["string", "null"]},
                "format_role": {
                  "enum": [
                    "control",
                    "header",
                    "input",
                    "label",
                    "output",
                    "period",
                    "reference",
                    "section_title",
                    "subheader"
                  ]
                },
                "editable": {"type": "boolean"}
              }
            }
          },
          "validation_ids": {"type": "array", "items": {"type": "string"}},
          "blockers": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "controls": {"type": "array", "items": {"type": "string"}}
  }
}
