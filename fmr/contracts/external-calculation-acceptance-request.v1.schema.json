{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/thedanieltan/financial-model-router-oss/fmr/contracts/external-calculation-acceptance-request.v1.schema.json",
  "title": "FMR external calculation acceptance request v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "input_filename", "output_filename", "input_workbook_base64", "calculated_workbook_base64", "write_plan", "execution_receipt", "engine_name", "engine_version"],
  "properties": {
    "contract_version": {"const": "external-calculation-acceptance-request.v1"},
    "input_filename": {"type": "string", "minLength": 1, "maxLength": 255, "pattern": "^[^/\\\\]+\\.xlsx$"},
    "output_filename": {"type": "string", "minLength": 1, "maxLength": 255, "pattern": "^[^/\\\\]+\\.xlsx$"},
    "input_workbook_base64": {"type": "string", "minLength": 1},
    "calculated_workbook_base64": {"type": "string", "minLength": 1},
    "write_plan": {"type": "object"},
    "execution_receipt": {"type": "object"},
    "engine_name": {"type": "string", "minLength": 1, "maxLength": 200},
    "engine_version": {"type": "string", "minLength": 1, "maxLength": 500}
  }
}
